{
  "manifest_version": 3,
  "name": "HTML Inspect",
  "version": "0.1.0",
  "key": "",
  "description": "Inspect live DOM structure, classes, styles, and layout data across one or two pages.",
  "permissions": ["alarms", "storage", "tabs", "scripting", "sidePanel", "webRequest", "debugger"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open HTML Inspect"
  },
  "web_accessible_resources": [
    {
      "resources": ["sidepanel.html", "sidepanel.js", "assets/*", "chunks/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
